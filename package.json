{
  "name": "painel-cadunico",
  "version": "1.0.9",
  "description": "Sistema de Painel de Atendimento On-Premise",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.8.3",
    "express": "^4.19.2",
    "googleapis": "^171.4.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.lucas.softwaretv",
    "productName": "Painel Cadunico",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      "banco_inicial.db"
    ],
    "publish": {
      "provider": "github",
      "owner": "Lucstarwork",
      "repo": "painel-cadunico"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  }
}
